<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Widget colors – dark mode, API 31+ (Material You dynamic tokens).
         Darker end of the wallpaper-derived neutral palette. -->

    <color name="widget_background">@android:color/system_neutral1_900</color>
    <color name="widget_primary_text">@android:color/system_neutral1_100</color>
    <color name="widget_secondary_text">@android:color/system_neutral1_300</color>
    <color name="widget_divider">@android:color/system_neutral1_600</color>

    <!-- Score change indicator colors for dark mode.
         Light shades (200/300) of wallpaper-derived accents ensure high contrast
         against the system_accent2_800 dark background.
         system_accent1_200: pale primary tint  → increase (green on this app's theme)
         system_accent3_300: light tertiary tint → decrease (complementary/warm contrast) -->
    <color name="widget_privacy_increase">@android:color/system_accent1_200</color>
    <color name="widget_privacy_decrease">@android:color/system_accent3_300</color>
</resources>

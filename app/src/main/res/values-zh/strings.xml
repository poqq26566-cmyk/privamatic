    <string name="privacy_check_device_encryption_name">设备加密</string>
    <string name="privacy_check_device_encryption_description">设备存储应进行加密，以便在设备丢失或被盗时保护你的数据</string>
    <string name="privacy_check_device_encryption_recommendation">在“设置 &gt; 安全 &gt; 加密”中启用设备加密（现代设备通常默认已启用）。</string>

    <string name="privacy_check_biometric_auth_name">生物识别认证</string>
    <string name="privacy_check_biometric_auth_description">应启用生物识别认证以增强安全性</string>
    <string name="privacy_check_biometric_auth_recommendation">在“设置 &gt; 安全 &gt; 生物识别”中设置指纹或人脸解锁，兼顾便利与安全。注意：如果你经常出入境或可能面临法律程序，仅使用 PIN 码能提供更强的保护，因为它无法被强制要求生理解锁。</string>
    <string name="privacy_check_biometric_auth_passing_note">你已设置生物识别解锁。注意：如果你经常出入境或可能面临法律程序，仅使用 PIN 码能提供更强的保护，因为它无法被强制要求生理解锁。</string>

    <string name="privacy_check_usb_debugging_name">USB 调试</string>
    <string name="privacy_check_usb_debugging_description">出于安全考虑，应关闭 USB 调试</string>
    <string name="privacy_check_usb_debugging_recommendation">在“设置 &gt; 开发者选项”中关闭 USB 调试，防止他人通过 USB 连接未经授权访问设备。</string>

    <string name="privacy_check_developer_options_name">开发者选项</string>
    <string name="privacy_check_developer_options_description">个人设备上应关闭开发者选项</string>
    <string name="privacy_check_developer_options_recommendation">在“设置 &gt; 系统 &gt; 开发者选项”中关闭开发者选项，以降低安全风险。</string>

    <string name="privacy_check_notification_listener_name">通知使用权</string>
    <string name="privacy_check_notification_listener_description">拥有通知使用权的应用可以读取所有通知，包括两步验证码和消息内容</string>
    <string name="privacy_check_notification_listener_recommendation">在“设置 &gt; 应用 &gt; 特殊应用访问权限 &gt; 通知使用权”中检查并撤销非必要应用的通知访问权限。</string>
    <string name="privacy_check_notification_listener_action">管理权限</string>

    <string name="privacy_check_accessibility_service_name">无障碍服务访问权限</string>
    <string name="privacy_check_accessibility_service_description">拥有无障碍服务权限的应用可以控制你的整台设备，甚至可能记录你的按键输入</string>
    <string name="privacy_check_accessibility_service_recommendation">在“设置 &gt; 无障碍”中关闭那些并不真正需要该权限的应用的无障碍服务。</string>
    <string name="privacy_check_accessibility_service_action">管理服务</string>

    <string name="privacy_check_device_admin_name">设备管理应用</string>
    <string name="privacy_check_device_admin_description">拥有设备管理权限的应用对你的设备具有更高的控制权</string>
    <string name="privacy_check_device_admin_recommendation">在“设置 &gt; 安全 &gt; 设备管理应用”中检查并移除非必要应用的设备管理权限。</string>
    <string name="privacy_check_device_admin_action">管理管理员</string>

    <string name="privacy_check_background_location_apps_name">后台位置访问权限</string>
    <string name="privacy_check_background_location_apps_description">拥有后台位置权限的应用可以随时追踪你的精确位置，即使未在使用该应用</string>
    <string name="privacy_check_background_location_apps_recommendation">在“设置 &gt; 位置信息 &gt; 应用权限”中检查并限制后台位置权限。只将“始终允许”授予真正需要的应用。</string>
    <string name="privacy_check_background_location_apps_action">管理权限</string>

    <string name="privacy_check_security_patch_name">安全补丁</string>
    <string name="privacy_check_security_patch_description">设备的安全补丁日期显示了上次修复已知漏洞的时间。补丁过旧会让设备暴露在已被修复的安全风险之下</string>
    <string name="privacy_check_security_patch_recommendation">在“设置 &gt; 系统 &gt; 系统更新”中检查更新。如果没有可用更新，你的设备可能已停止维护，厂商不再提供支持。</string>
    <string name="privacy_check_old_target_sdk_name">过时的应用兼容性</string>
    <string name="privacy_check_old_target_sdk_description">目标版本为 Android 5.1 或更早的应用会绕过现代权限控制机制，可在未事先询问的情况下访问敏感数据</string>
    <string name="privacy_check_old_target_sdk_recommendation">检查并卸载目标版本过旧的应用。这些应用是在运行时权限机制出现之前开发的，可能在不知不觉中访问联系人、存储等敏感数据。请寻找更新版本或现代替代品。</string>

